# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/campaign
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/campaign

# Supabase — https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=

# Supabase direct DB connection — used only by `pnpm db:migrate`
# Get from Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Public app URL — used for sitemap, robots.txt, and OG metadata
NEXT_PUBLIC_APP_URL=https://your-domain.com
